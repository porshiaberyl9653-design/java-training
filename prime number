import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int n;
        int count=0;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        for(int i=1;i<=n;i++)
        {if(n%i==0)
            count++;
        }
        if(count==2)
            System.out.println("Prime");
        else
            System.out.println("Not Prime");
    }
}
