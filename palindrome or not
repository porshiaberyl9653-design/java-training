import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int n;
        int reverse=0;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        int temp=n;
        while(n>0)
        { int d=n%10;
          reverse=reverse*10+d;
          n=n/10;
        }
        if(temp==reverse)
        System.out.println("Palindrome");
        else
        System.out.println("Not Palindrome");
        
    

    }
}
