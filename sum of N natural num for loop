import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int n;
        int i=1;
        Scanner s=new Scanner(System.in);
        int sum=0;
        n=s.nextInt();
        for(i=1;i<=n;i++)
        { sum=sum+i;
        }
        System.out.println(sum);
    }
}
